////////////////////////////////////////////////////////////////////////////////////////////////////
//
//   This tests if w is a partial permutation.  1 = yes and 0 = no
//
proc isPartialPermutation( intvec w )
"USAGE:  isPartialPermutation( w );  w intvec
   
 RETURN: int: 1 if the integer vector is a partial premutation in that it has distinct positive entries.
              0 if it is not a partial permutation.
   
 EXAMPLE: example isPartialPermutation; shows an example"
{
  intvec u = sort(w)[1];
  if (u[1] < 1) { return( 0 ); }
  for (int i=1; i<nrows(u); i=i+1) {
   if (u[i] == u[i+1]) { return( 0 ); } 
  }
  return( 1 );
}
example
{
  "EXAMPLE:"; echo = 2;   
  isPartialPermutation( intvec( 1, 4, 3, 7 ) );
  isPartialPermutation( intvec( 1, 4, 3, 4 ) );
  isPartialPermutation( intvec( 1,-1, 3, 4 ) );
}
// should get the values 1, 0, 0 from these inputs
////////////////////////////////////////////////////////////////////////////////////////////////////
//  Checks if integer d is a component of vector a, returning a boolean 1/0    
//
//   This is static and not exported
//
proc belongsTo (int d, intvec a)
"USAGE:  belongsTo(d, a);  d int, a intvec

 RETURN: int: 1 if d is a component of a  and  0 if it is not
 
 EXAMPLE: example belongsTo; shows an example"
{
  for (int i=1; i<=nrows(a); i++) {
    if (d==a[i]) { return(1) }
  }
  return(0);
}
example   
{   
  "EXAMPLE:"; echo = 2;   
  intvec myFlagType = 2,3,5;   
  int d = 3;   
  belongsTo(d, myFlagType);   
} 
////////////////////////////////////////////////////////////////////////////////////////////////////
//  Checks if partial permutation w is a Schubert condition for the
//     flag manifold of type flagType                                                             
//
proc isCondition (intvec w, intvec flagType)
"USAGE:  isCondition( w, flagType);  w intvec, flagType intvec
   
 RETURN: int: 1 if the partial permutation w has descents in the set flagType
              0 if not, including if it is not a partial permutation.
	This is the requirement that w is a Schubert condition for the flag variety
              encoded by flagType
   
 EXAMPLE: example isCondition; shows an example"
{
  int fits = isPartialPermutation( w ) * belongsTo(nrows(w), flagType);
  if (fits==1)
  {
    for (int i=1; i<nrows(w); i++)
    {
      if (w[i]>w[i+1]) { fits = fits * belongsTo(i,flagType); }
    }
  }
  return( fits );
} 
example   
{   
  "EXAMPLE:"; echo = 2;   
  intvec w = 1,4,3;   
  intvec flagType = 2, 3, 5;   
  isCondition(w, flagType);   
  isCondition(intvec(1,4), flagType);   
  isCondition(intvec(1,4,3), flagType);   
}
// should get the values 1, 1, 0 from these inp[uts
////////////////////////////////////////////////////////////////////////////////////////////////////

////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  This is a helper function for making Stiefel coordinates in type A.  It returns a list of indices of the 
//    variables in the Stiefel coordinates w.r.t. the standard coordinate flag.
//      
//  This is typically called with a flagType and a list of a single condition w and 
//    returns data for Steifel coordinates for a Schubert cell X_w, but
//    if the flagType is a Grassmannian, there may be two conditions and it will  
//    return Stiefel coordinates for a Richardson variety.
//
//  This is an internal procedure and will not be exported.
//
//    Does not yet check that the Schubert condition fits the flagType
//
proc indicesOfVariables ( intvec flagType , list conditions )
"USAGE:  list L =indicesOfVariables( flagType, conditions); 
      flagType describes the type of the flag manifold
      conditions is a list of one to two  permutations for flagType that describe the Stiefel coordinates
             (two only when flagType is a Grassmannian)

 RETURN: a list of integer vectors of length 2. 
   
 EXAMPLE: example indicesOfVariables; shows an example"
{
  if ( size(conditions)>2  or size(conditions)==0 )
  {
    printf("Input failure, Stiefel Coordinates requires at most two conditions.  You inputted %s.", size(conditions));
    quit;
  }
  if (not isCondition( conditions[1], flagType))
  {
    printf("Input failure, (%s) is not a Schubert condition for the flag variety (%s).", conditions[1], flagType);
    quit;
  }
  int a,i,j;
  int n = flagType[nrows(flagType)];
  list indicesOfVariables = list();
  //  Finds the indices of variables in type A Stiefel coordinates, in the case when there is one Schubert condition
  intvec w = conditions[1];
  if (size(conditions) == 1)
  {
    intvec extendedFlagType = intvec(0), flagType;
    for (a=1; a<nrows(flagType); a++)
    {
      for (j=extendedFlagType[a]+1; j<=flagType[a]; j++)
      {
        for (i=1; i<=n-w[j]; i++)
        {
          if (not belongsTo(n+1-i , intvec(w[1..flagType[a]])) )
          {
            indicesOfVariables = insert( indicesOfVariables, intvec(i,j) );
          }
        }
      }
    }
    return( indicesOfVariables );
  }
 else
  //   If there are two Schubert conditions, then we must be on a Grassmannian
  {
    if (nrows(flagType) > 2)
    {
      printf("Input failure for flagType = intvec (%s), conditions = list ( intvec (%s), intvec (%s) ) :",
                flagType, conditions[1], conditions[2]);
      printf("The flag variety is not a Grassmannian, as flagType = (%s), and the Richarson variety",flagType);
      printf("option requires a Grassmannian.");
      quit;
    }
     if (not isCondition( conditions[1], flagType))
    {
      printf("Input failure, (%s) is not a Schubert condition for the flag variety (%s).", conditions[2], flagType);
      quit;
    }
    intvec v = conditions[2];
    int k = flagType[1];
    for (j=1; j<=k; j++)
    {
      if ( n+1 < w[j] +v[k+1-j] )
      {
        printf("Input failure  for flagType = intvec (%s), conditions = list ( intvec (%s), intvec (%s) ) :",
                 flagType, conditions[1], conditions[2]);
        printf("The conditions (%s) and (%s) define an empty Richardson variety",w,v);
        quit;
      }
      for (i=v[k+1-j]; i<=n-w[j]; i++)
      {
        indicesOfVariables = insert( indicesOfVariables, intvec(i,j) );
      }
    }
    return( indicesOfVariables );
  }
}
example   
{   
  "EXAMPLE:"; echo = 2;
  intvec myFlagType =  2, 3, 6;
  intvec w = 2,6, 4, 1,3,5;
  list myConditions = w ;
  list L  = indicesOfVariables( myFlagType, myConditions );
  print(L[1]);
  print(L[2]);
} 
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  This finds the positions of the essential conditions in a Schubert condition for the classical Grassmannian
//
proc jumps (intvec condition)
"USAGE: intvec essC = jumps( w )
  w is a partial permutation
 RETURN: The vector of positions i where w[i-1] + 1 < w[i] (w[0]=0)  --- the essential Conditions
 EXAMPLE: example jumps shows an example"
{
  intvec w = sort(condition)[1];
  intvec jmps;
  int i,val;
  val=0;
  for (i=1; i<=nrows(w); i++) 
  {
    if (val+1 < w[i]) 
    {
      jmps= jmps, i;
    }
    val = w[i];
  }
  return(intvec(jmps[2..nrows(jmps)]));
}
example   
{   
  "EXAMPLE:"; echo = 2;
  jumps(intvec(1, 2, 4, 6));
} 
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//  Gets the descent set of a partial permutation w.                                              //
//
proc getDescents (intvec w)

"USAGE:  getDescents( w );  w intvec
 RETURN: The integer vector whose components are the descent set { i : w[i]>w[i+1] } of w.
 NOTE: This does not check that w is a partial permutation, but it does complete it to a permutation.
 EXAMPLE: example getDescents; shows an example"
{
  if ( isPartialPermutation( w )<>1 )
  {
    print("Input (%s) to getDescents is not a partial permutation.",w);
    quit;
  }
  intvec descents;
  intvec u = sort(w)[1];
  int n = u[nrows(w)];
  u = completeToPermutation( w, n );
  for (int i=1; i<=nrows(u)-1; i++) {
    if (u[i]>u[i+1]) { descents = descents , intvec(i) ; }
  }
  if (nrows(descents)>1) {descents = descents[2..size(descents)];}
  return ( descents );
}
example   
{   
  "EXAMPLE:"; echo = 2;   
  intvec w = 3,5, 1,6, 2,7;   
  getDescentsA( w );
}
//   The result should be 2, 4, 6
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//  Completes a partial permutation w to a full permutation for S_n                               //
//
proc completeToPermutation ( intvec w, int n )
"USAGE:  intvec w = completeToPermutation( w, n);  w intvec, n int
   
 RETURN: The full permutation in S_n whose initial values agree with w, and remaining values are increasing.

 EXAMPLE: example completeToPermutation; shows an example"
{
  if ( isPartialPermutation(w) <>1 )
  {
    printf("Input failure for completeToPermutation ( intvec (%s), int %s ) :",w, n);
    printf("The vector (%s) is not a partial permutation.",w);
    quit;
  }
  if ( nrows(w) < n )
  {
    for ( int i=1; i<=n; i++ )
    {
      if (belongsTo(i,w)==0) { w = w, intvec(i); }
    }
  }
  return ( w );
}
example   
{   
  "EXAMPLE:"; echo = 2;   
  intvec w = 1,4,3;   
  int n = 5;   
  completeToPermutation(w, n);   
}
//   The result should be 1,4,3,2,5
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//  Computes one step in the lexicographic walk through Pluecker indices on a Grassmannian
//
proc plueckerStep( intvec w, int n )
"USAGE: intvec u = plueckerStep( condition, dimension ); 

  condition is a Schubert condition/Pluecker index for the Grassmannian Gr( nrows(w), dimension), 
        an increasing sequence of integers in [1, dimension]

 RETURN: The next index of a Pluecker coordinate for Gr( nrows(u), dimension) in lexicographic order,
          or the intvec (0) if the w was the maximal Pluecker index

 EXAMPLE: example plueckerStep shows an example"
 {
  int k = size(w);
  //          Check  if the input is valid  (this was tested)
  intvec sw = sort(w)[1];
  if (isPartialPermutation( w ) <> 1  or sw <> w or sw[k]>n )
  { 
    printf("Input failure for plueckerStep ( intvec (%s), int %s ) :", w,n);
    printf("The vector (%s) is not a Schubert condition for Gr(%s,%s).",w,k,n);
    quit;
  }
  //       returns (0) if w was the largest Pluecker index
  if ( w[1] == n+1-k ) { return( intvec(0) ); }
  //
  for (int i=1; i<=k; i=i+1)
  {
     if (w[k+1-i] < n+1-i) {break;}
  }
  int old = w[k+1-i];
  for (int j=i; j>=1; j=j-1)
  {
    w[k+1-j] = old+i+1-j;
  }
  return( w );
 }
 example   
 {
   "EXAMPLE:"; echo = 2;   
   intvec w = 1,5,6;   
   int n = 6;   
   plueckerStep(w, n);   
 }
//   The result should be 2,3,4
///////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//  Computes the list of n choose k Pluecker indices on a Grassmannian
//
//   Need to check that k < n
//
proc plueckerIndices( int k, int n )
"USAGE: list L = plueckerIndices( k, n );   int k,  int n

  RETURN: The complete list of all Grassmannian Schubert condition for Gr( k , n )) in lexicographic order.
           This is to  generate equations for Schubert varieties
 
  NOTE: This is for the Grassmannian Gr( k , n ) 

 EXAMPLE: example plueckerIndices shows an example"
 {
  intvec w = 1..k;
  list L=list(w);
  while (1)
   {
    w  = plueckerStep(w,n);
    if (not w[1]) {break;}
    L = insert(L,w,size(L));
   }
  return(L);
 }
 example
 {
   "EXAMPLE:"; echo = 2;   
   plueckerIndices( 2 , 4 );
 }
//   The result should be [ [1,2], [1,3], [1,4], [2,3] [2,4], [3,4] ]
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
// This takes a pair of a list of indices (n choose k) and a n x k matrix myMatrix and returns
//   the list of Pluecker vectors of myMatrix.
//
//  Warning:  This internal procedure assumes that the first list is indeed the set n choose k,
//              and the matrix has given format.  It provides no checks, assuming that the parent
//              procedure performs the check.
//
//  Missing checks and example
//
//
proc plueckerVector ( list plIndices, matrix myMatrix )
"USAGE: list L = plueckerVector( plIndices, myMatrix )

   This takes a pair of a list of indices (n choose k) and a n x k matrix myMatrix

  Warning:  This internal procedure assumes that the list is a list of k element subsets of row indices of myMatrix,
                and that myMatrix has k columns. It provides no checks, assuming that the parent
                procedure performs the check.

 RETURN: The list of Pluecker vectors of myMatrix with indices in plIndices

 EXAMPLE: example plueckerVector shows an example"
{
  list plCoords = list();
  int k = nrows(plIndices[1]);
  for (int i=1; i<=size(plIndices); i++)
  {
    plCoords = insert(plCoords, det(submat(myMatrix,plIndices[i],1..k)), i-1);
  }
  return(plCoords)
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Computes the dual Pluecker index to w for Grass (k, n)
//
//  Needs checks, documentation, and example
//
proc dualIndex( intvec w, int n )
{
  intvec dualCondition;
  int k = size( w );
  for (int i=1; i<=k; i++)
  {
    dualCondition[i]=n+1-w[k+1-i];
  }
  return(dualCondition)
}
example   
{   
  "EXAMPLE:"; echo = 2;
   intvec w = 1,2,5;
   int n = 7;
   dualIndex( w, n );
}
// should get 3,6,7
////////////////////////////////////////////////////////////////////////////////////////////////////.
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Computes the Boolean that firstIndex \leq secondIndex in the Bruhat order on the Grassmannian
//
//   Need to check that they are both Pluecker indices for the same Grassmannian
//
proc  leqPluecker( intvec firstIndex, intvec secondIndex)
{
  int k = nrows(secondIndex);
  if (nrows(firstIndex) <> k )
  {
    print("Incompatible inputs to leqPluecker.  They need to have the same length")'
    quit;
  }
  int comparable = 1;
  for (int i=1; i<=k; i++)
  {
    comparable = comparable * ( firstIndex[i] <= secondIndex[i]);
  }
  return(comparable)
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Computes all Pluecker indices from pIndices for Gr(k,n)  that are not less than w
//
//   Needs documentation and example
//
//
proc allNotLessThan( intvec w, int n, list pIndices)
{
  int i;
  int k = nrows( w );
  intvec dualCondition = dualIndex( w, n );
  list L;
  for (i=1; i<=size(pIndices); i++)
  {
    if (not leqPluecker(pIndices[i], dualCondition))
    {
      L = insert( L, pIndices[i]);
    }
  }
  return(L);
}
////////////////////////////////////////////////////////////////////////////////////////////////////
///// &&&&&&&&&&&&&&&&&&&&&&&&&&&&    Type C  helper routines     &&&&&&&&&&&&&&&&&&&&&&&&&&&&//////
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Tests if w is a partial permutation in the Weyl group C_n
//
proc isPartialPermutationC( intvec w, int n )
"USAGE:  isPartialPermutationC ( w, n );    w intvec, n int
RETURN: int: 1 if w is a partial permutation in C_n in that it has distinct entries in [1, 2n],
                and no two sum to 2n+1
             0 if it is not in C_n
EXAMPLE: example isPartialPermutationC; shows an example"
{
  int i,j;
  int m = nrows(w);
  intvec u = sort(w)[1];
  if (u[1] < 1 or u[m]>2*n) { return(0); }
  for (i=1; i<m; i++)
  {
    if (u[i]==u[i+1]) { return(0); }
    for (j=i+1; j<=m; j++)
    {
      if (u[i]+u[j] == 2*n+1) { return(0==1); }
    }
  }
  return( 1 );
}
example
{
  "EXAMPLE:"; echo = 2;
  isPartialPermutationC ( intvec(1, 5, 3), 3 );
  isPartialPermutationC ( intvec(1, 5, 3), 4 );
  isPartialPermutationC ( intvec(1, 4, 5), 4 );
}
//  Answers should be  1 1 0
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  checks that w is a condition for the Lagrangian Grassmannian
//
proc isLagrangianCondition ( intvec w )
"USAGE:  isLagrangianCondition ( w );   w intvec
RETURN: int: 1 if w is a Schubert condition for the Lagrangian Grassmannian in that if n=nrows(w),
               then w is a partial permutation in C_n and is increasing order
             0 otherwise
EXAMPLE: example isLagrangianCondition; shows an example"
{
  int n = nrows( w );
  intvec u = sort(w)[1];
  if (u<>w) { return(0); }
  return( isPartialPermutationC( w, n) );
}
example
{
  "EXAMPLE:"; echo = 2;     
   isLagrangianCondition( intvec(1,5,4) );
   isLagrangianCondition( intvec(1,3,5) );
}
// Should get 0 1
////////////////////////////////////////////////////////////////////////////////////////////////////


////////////////////////////////////////////////////////////////////////////////////////////////////
//
// compute decomposition points of a pair of Schubert conditions for a Lagrangian Grassmannian
//
proc makeDecompositionPointSet ( intvec w_internal, intvec u_internal )
"USAGE:  makeDecompositionPointSet( w, u );    w, u intvec of the same nrows n
RETURN: the integer vector of decomposition points for the pair  w_internal, u_internal, which is the 
               set of indices i such that 2*n+1 < w[i+1] + u[n+1-i]
EXAMPLE: example makeDecompositionPointSet; shows an example"
{
  int n = nrows( w_internal );
  intvec decPts=0;
  for (int i=1; i<n; i++)
  {
    if (2*n+1<w_internal[i+1]+u_internal[n+1-i])
    {
      if (decPts[1]==0)
      {
        decPts = i;
      }
      else
      {
        decPts = decPts, i;
      }
    }
  }
  return( decPts );
}
example
{
  "EXAMPLE:"; echo = 2;     
   makeDecompositionPointSet( intvec(1,2,3,7,9), intvec(1,4,6,8,9) );
   makeDecompositionPointSet( intvec(1,2,3,6,7), intvec(1,4,5,8,9) );
}
// Should get (3,4) and (0)
////////////////////////////////////////////////////////////////////////////////////////////////////
//
// compute one step of a decomposition of a pair of Schubert conditions for a Lagrangian Grassmannian
//
proc decomposePair ( intvec wo, intvec uo )
"USAGE: decomposePair ( w, u );      w, u intvec of the same nrows n and decomposable
RETURN: A list of four Schubert conditions cw, cu, wp, up coming from the decomposition.
          The first two are from the beginning and end of wo, uo, and have a unique decomposition point.
          The second two are the residual conditions from the inside.
EXAMPLE: example decomposePair; shows an example"
{
  intvec wp, up;
  intvec dP = makeDecompositionPointSet( wo, uo );

  if (nrows(dP)>1)
  {
    int n_int = nrows(wo);
    int a_int = dP[1];
    int b_int = n_int - dP[nrows(dP)];
    int m = dP[nrows(dP)] - a_int;
    intvec cw = wo[1..a_int];
    intvec cu = uo[1..b_int];
    for (int i=1; i<=b_int; i++)
    {
      cw[a_int+i] = wo[ n_int-b_int+i ] - 2*m;
    }
    for (i=1; i<=a_int; i++)
    {
      cu[b_int+i] = uo[ n_int-a_int+i ] - 2*m;
    }
    for (i=1; i<=m; i++)
    {
      wp[i] = wo[ a_int + i ] - a_int - b_int;
      up[i] = uo[ b_int + i ] - a_int - b_int;
    }
  return( list ( cw, cu, wp, up ) );
  }
  return("FAIL: This needs to be called on a decomposable pair");
}
example
{
  "EXAMPLE:"; echo = 2;     
   decomposePair( intvec(1,2,5,7,8), intvec(1,3,5,7,9) );
   decomposePair( intvec(1,2,4,6,8), intvec(1,4,5,8,9) );
}
// The first is [ intvec(1,2,5,6), intvec(1,3,5,7), intvec(1), intvec(1) ]
// The second is [ intvec(1,2,4),  intvec(1,4,5),  intvec(1,3),  intvec(1,2) ]
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Compute the full decomposition of a pair of Scubert conditions for the Lagrangian Grassmannian
//
proc fullDecomposition( intvec wo, intvec uo )
"USAGE: fullDecomposition( w, u );  w, u Schubert conditions for the same Lagrangian Grassmannian
RETURN: A lists of lists (pairs) [ [w1,u1], [w2,u2], ..., [ws, us] ] such that the Richardson
         variety Y(w,u) decomposes as X(w1,u1) x X(w2,u2) x ... x Y(us,ws)
EXAMPLE: example fullDecomposition; shows an example"
{
  intvec w_tmp = wo;
  intvec u_tmp = uo;
  list L, components;
  while (nrows(makeDecompositionPointSet( w_tmp, u_tmp )) > 1)
  {
     L = decomposePair( w_tmp, u_tmp );
     components = components + list(list( L[1], L[2] ));
     w_tmp = L[3];
     u_tmp = L[4];
  }
  return( components + list(list( w_tmp, u_tmp )) );
}
example
{
  "EXAMPLE:"; echo = 2;     
   fullDecomposition( intvec(1,2,3,6, 8,10,11,13,16,18,20,21), intvec(1,4,6,7,10,11,13,16,17,20,22,23) );
}
// This returns
// [1]:
//    [1]:
//       1,2,3,6,7
//    [2]:
//       1,4,6,8,9
// [2]:
//    [1]:
//       1,3,5,7
//    [2]:
//       1,2,5,6
// [3]:
//    [1]:
//       1,2,4
//    [2]:
//       1,2,4
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Compute the indices of variables and of dependent for a single Schubert cell in the Lagrangian Grassmannian
//    This is a helper function for  coordinates for Richardson varieties in the Lagrangian Grassannian.
//
proc LagrIndicesPlain( intvec w )
"USAGE: LagrIndicesPlain( w );   w a Schubert condition for a Lagrangian Grassmannian
RETURN: List L of lists.  L[1] are the indices (positions) of the variables in the Schubert cell given by w
                          L[2] indicates the dependent variables, this is a list of triples: position, position of variable, sign
EXAMPLE: example LagrIndicesPlain shows an example"
{
  int n = nrows(w);
  int i,j;
  //
  //  Need wo (prepending 0)  to get indices of variables
  //
  intvec wo = intvec(0), w;
  ////     Make indices of variables
  list indsOfVariables = list();
  for (i=1; i<=n; i++)
  {
     for (j=1; j<=n; j++)
     {
       if (wo[j] < w[i] and w[i] < 2*n+1-w[j]) { indsOfVariables = insert( indsOfVariables, intvec(w[i],j) ); }
     }
  }
  ////     Indices of dependent variables
  list dependency, dependentVariables;
  for (j=2; j<=n; j++)
  {
     for (i=1; i<=j; i++)
     {
        if (w[i] < w[j] and w[i] < 2*n+1-w[j])
        {
          dependency = list( intvec(w[i],j), intvec(w[j],i), 1);
	  if (w[j]>n) { dependency[3] = -1; }
	  dependentVariables = insert( dependentVariables, dependency );
        }
     }
  }
  return( list( indsOfVariables, dependentVariables) );
}
example
{
  "EXAMPLE:"; echo = 2;     
   LagrIndicesPlain( intvec(1,3) );
}
//  This returns:
//[1]:
//   [1]:
//      3,1
//   [2]:
//      1,1
//[2]:
//   [1]:
//      [1]:
//         1,2
//      [2]:
//         3,1
//      [3]:
//         -1
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Returns the indices of a Richardson variety.
//  A helper function for  coordinates for Richardson varieties in the Lagrangian Grassannian.
//    This could be reporposed in the Stiefel coordinates for Richardsons in the classical Grassmannian.
proc LagrIndicesRichardson ( intvec w, intvec u )
"USAGE: LagrIndicesRicharadson( w, u );   w, u are Schubert conditions for a Lagrangian Grassmannian
RETURN: List L of pairs, each of which indexes a variable in Stiefel coordinates fora Richardson variety.
          It is assumed that the 1s are in positions 2n+1-w[i],i.
EXAMPLE: example LagrIndicesRichardson shows an example"
{
  int n = nrows(w);
  int i,j;
  ////     Make indices of variables
  list indsOfVariables = list();
  for (j=1; j<=n; j++)
  {
     for (i=u[n+1-j]; i<=2*n-w[j]; i++)
     {
       indsOfVariables = insert( indsOfVariables, intvec(i,j) ); 
     }
  }
  return( list(indsOfVariables, list()) );
}
example
{
  "EXAMPLE:"; echo = 2;     
   LagrIndicesRichardson( intvec(1,2,4), intvec(1,3,5) );
}
// This returns:
//[1]:
//   [1]:
//      2,3
//   [2]:
//    1,3
//   [3]:
//      4,2
//   [4]:
//      3,2
//   [5]:
//      5,1
//[2]:
//   empty list
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  This give indices of variables for the remarkably small Stiefel coordinates when w and u have a
//     single decomposition point and u has a special form
//
proc  LagrIndicesRichSplit ( intvec w, intvec u )
"USAGE: LagrIndicesRicharSplit( w, u );   w, u are Schubert conditions for a Lagrangian Grassmannian with a single decomposition point
RETURN: List L of pairs, each of which indexes a variable in Stiefel coordinates fora Richardson variety.
          It is assumed that the 1s are in positions 2n+1-w[i],i, and that u has a special form.
EXAMPLE: example LagrIndicesRichSplit shows an example"
{
  intvec DP = makeDecompositionPointSet( w, u );
  if ( nrows(DP) > 1 )
  {
    print("The input data has more than one decomposition point.");
    quit;
  }
  if ( DP[1]==0 )
  {
    print("The input data is not decomposable.");
    quit;
  }
  int a =  makeDecompositionPointSet( w, u )[1];
  int n = nrows(w);
  int b = n-a;
  int i,j;
  intvec wo = intvec(0), w;
  if ( u[b]>b )
  {
    print("The pair is not in the correct form to make great coordinates.");
    quit;
  }
  //  This is to cutoff the 
  intvec cutOff = w*0;
  cutOff[a] = u[n+1-a]-1;
  for (i=n-1; i>0; i=i-1) { cutOff[i] = max( cutOff[i], cutOff[i+1] ); }

  list indsOfVariables = list();
  for (i=1; i<=n; i++)
  {
    for (j=1; j<=n; j++)
    {
      if ( max(wo[j],cutOff[j]) < w[i] and w[i] < 2*n+1-w[j]) { indsOfVariables = insert( indsOfVariables, intvec(w[i],j) ); }
    }
  }
 ////     Indices of dependent variables
  list dependency, dependentVariables;
  for (j=2; j<=n; j++)
  {
     for (i=1; i<=j; i++)
     {
        if (w[i] < min( w[j], 2*n+1-w[j]) and w[j]>n )
        {
          dependency = list( intvec(w[i],j), intvec(w[j],i),-1);
	  dependentVariables = insert( dependentVariables, dependency );
        }
     }
  }
  return( list( indsOfVariables, dependentVariables) );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//   Rotates the variables, for when u and w are interchanged in making Lagrangian Richardson Coordinates
//
proc rotateVars ( list L)
{
  int n = nrows(L[3]);
  intvec tmp = L[3];
  for (int i=1; i<=size(L[1]); i++)
  {
    L[1][i][1] = 2*n+1-L[1][i][1];
    L[1][i][2] =   n+1-L[1][i][2];
  }
  for (i=1; i<=size(L[2]); i++)
  {
    L[2][i][1][1] = 2*n+1-L[2][i][1][1];
    L[2][i][2][1] = 2*n+1-L[2][i][2][1];
    L[2][i][1][2] =   n+1-L[2][i][1][2];
    L[2][i][2][2] =   n+1-L[2][i][2][2];
  }
  for (i=1; i<=n; i++)
  {
    L[3][i] = 2*n+1-tmp[n+1-i];
  }
  return(L);
}
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//   Computes a dual Schubert condition for the Lagrangian Grassmannian
//
proc dualIndexC ( intvec w )
{
  if (isLagrangianCondition( w ))
  {
    return( dualIndex( w, 2*nrows(w) ) );
  }
  print("Not a condition for the Lagrangian Grassmannian! (in proc DualIndexC)");
  quit;
}
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Rotates a Schubert condition
//
proc rotateC (intvec w )
{
  intvec wOut;
  int n = nrows(w);
  for (int i=1; i<=n; i++) { wOut[i] = 2*n+1-w[i]; }
  return( wOut );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  This is procedure decomposes a Lagrangian Richardson variety Y^u_w into a product X^u1_w1 x ...x X^ul_wl x Y^uo_wo, 
//    according to the decompositions of (w,u), and takes advantage of propitious choices of coordinates.
//    It does not handle fixed points/full columns
//    It is a helper function for makeLagrangianCoordinates
//
proc LagrangianVariables_nFP( intvec w, intvec u)
{
  int ai,bi,ni,n,i,j,nOld,iL;
  list Variablesi, myVariables, L;  // myVariables will be a triple; the third will give the positions of the 1s
  intvec wi, ui, newOnes;
  n = nrows(w);
  L = fullDecomposition( w, u );
  // Need to make the sets of indices.  Start from the inside
  nOld = 0;
  for (iL=size(L); iL>=1; iL=iL-1)
  {
    wi = L[iL][1];
    ui = L[iL][2];
    ni = nrows( wi );
    ai = makeDecompositionPointSet( wi, ui )[1];

    bi = ni-ai;
    // check which of the routines for indices of variables needs to be called
    if ( ai == 0 )                    // this is the last pair, and it is indecomposable
    {
      if (ui[ni] == ni)             // ui is the empty condition, can use Plain Lagrangian for wi 
      {
        Variablesi = LagrIndicesPlain( wi ) + list( rotateC( wi ) );
      }
      else
      {
        if (wi[ni] == ni)           // wi is the empty condition can use  Plain Lagrangian for ui, but need to reverse
        {
          Variablesi = rotateVars( LagrIndicesPlain( ui ) + list( rotateC( ui ) ) );
        }
        else                        // just use Richardson coordinates
        {
          Variablesi = LagrIndicesRichardson( wi, ui ) + list( rotateC( wi ) ); 
        }
      }
    }
    else                            // This is decomposable
    {
      if (ui[bi] == bi)             // We can use the smaller coordinates for (wi, ui)
      {
        Variablesi = LagrIndicesRichSplit(wi, ui) + list( rotateC( wi ) );
      }
      else                       
      {
        if (wi[ai] == ai)           // We can use the smaller coordinates for (ui, wi), but need to reverse
        {
          Variablesi =  rotateVars( LagrIndicesRichSplit(ui, wi) + list( rotateC( ui ) ) );
        }
        else                        // We have to use  Richardson coordinates
        {
          Variablesi = LagrIndicesRichardson( wi, ui ) + list( rotateC( wi ) ); 
        }
      }
    }
    //    We now have the new coordinates
    if (nOld == 0)                 // This is the first time through the loop
    {
      myVariables = Variablesi;
    }
    else                           // need to merge things together
    {
      // First, shift myVariables
      for (i=1; i<=size(myVariables[1]); i++)
      {
        myVariables[1][i][1] = myVariables[1][i][1]+ni;
        myVariables[1][i][2] = myVariables[1][i][2]+ai;
      }
      for (i=1; i<=size(myVariables[2]); i++)
      {
        myVariables[2][i][1][1] =  myVariables[2][i][1][1] + ni;
        myVariables[2][i][2][1] =  myVariables[2][i][2][1] + ni;
        myVariables[2][i][1][2] =  myVariables[2][i][1][2] + ai;
        myVariables[2][i][2][2] =  myVariables[2][i][2][2] + ai;
      }
      // next, shift Variablesi.  These are always in block form  Lower left, upper right
      for (i=1; i<=size(Variablesi[1]); i++)
      {
        if ( Variablesi[1][i][2] > ai )                       // upper right block
        {
          Variablesi[1][i][2] = Variablesi[1][i][2] + nOld;
        }
        else                                                 // lower left block
        {
          Variablesi[1][i][1] = Variablesi[1][i][1] + 2*nOld;
        }
      }
      for (i=1; i<=size(Variablesi[2]); i++)          // shift the linked variables, if any
      {
        if ( Variablesi[2][i][1][2] > ai )                      // upper right block
        {
          Variablesi[2][i][1][2] = Variablesi[2][i][1][2] + nOld;
          Variablesi[2][i][2][1] = Variablesi[2][i][2][1] + 2*nOld;
        }
        else                                               // lower left block
        {
          Variablesi[2][i][1][1] = Variablesi[2][i][1][1] + 2*nOld;
          Variablesi[2][i][2][2] = Variablesi[2][i][2][2] + nOld;
        }
      }
      // Concatenate the two lists  
      myVariables[1] = myVariables[1] + Variablesi[1];
      myVariables[2] = myVariables[2] + Variablesi[2];
      for (i=1; i<=ai; i++) { newOnes[i] = Variablesi[3][i]+2*nOld; }
      for (i=1; i<=nOld; i++)
      {
        newOnes[ai+i] =  myVariables[3][i]+ni;
      }
      for (i=ai+1; i<=ni; i++)
      {
        newOnes[nOld+i] = Variablesi[3][i];
      }
      myVariables[3] = newOnes;
    }
    nOld = nOld + ni;
  }
  return( myVariables );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
proc fullColData ( intvec wi, intvec ui )
//
//  This returns a list of pairs ( i, wi[i] ) such that wi[i] + ui[n+1-i] = 2n + 1 
//
{
   int n = size(wi);
   list fCD = list();
   for (int i=1; i<=n; i++){
     if (wi[i]+ui[n+1-i]==2*n+1) { fCD = insert( fCD, list( i, wi[i]) ); }
   }
   return( fCD );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
proc removeFP ( oldCond, fCD )
//
//  Removes the full columns from the permutations
//
{
  int idx, n, ii, skip, decr;
  n = size( oldCond );
  intvec newCond;
  for (idx=1; idx<=n; idx++) {
    skip = 0;
    decr = 0;
    for (ii=1; ii<=size(fCD); ii++){
      if (fCD[ii][2] == oldCond[idx] or fCD[ii][2] + oldCond[idx] == 2*n+1 ) { skip=1; } 
      if (fCD[ii][2] <  oldCond[idx]) { decr = decr + 1; } 
      if (2*n+1 < fCD[ii][2] +  oldCond[idx]) { decr = decr + 1; } 
    }
    if (skip == 0) {
      if (newCond[1] == 0) { newCond[1] = oldCond[idx] - decr; }
      else { newCond = newCond, intvec( oldCond[idx] - decr ); }
    }
  }
  return(newCond);
}
///////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Procedure for pointers inverting the map that removes fixed points
//
proc makeFP_pointers ( intvec w, intvec u ) {
  int ii,jj,inc;
  list fcd  = fullColData( w, u );
  int l = size(fcd);
  int n = size(w);
  intvec row_p = 1..2*(n-l);
  intvec col_p = 1..n-l;
  
  intvec cDec = 1..n;
  for (jj=1; jj<=l; jj++) {
    cDec[fcd[jj][1]] = -1;
  }
  inc = 0;
  for (ii=1; ii<=n; ii++) {
    if ( cDec[ii]<0 ) { inc = inc + 1; }
    else {col_p[ii-inc] = ii;}
  }
  intvec rDec = 1..2*n;
  for (jj=1; jj<=l; jj++) {
    rDec[fcd[jj][2]] = -1;
    rDec[2*n+1-fcd[jj][2]] = -1;
  }
  inc = 0;
  for (ii=1; ii<=2*n; ii++) {
    if ( rDec[ii]<0 ) { inc = inc + 1; }
    else {row_p[ii-inc] = ii;}
  }
  return( list(col_p, row_p) );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  This procedure decomposes a Lagrangian Richardson variety Y^u_w into a product X^u1_w1 x ...x X^ul_wl x Y^uo_wo, 
//    according to the decompositions of (w,u), and takes advantage of propitious choices of coordinates.
//    It takes care of fixed points/full columns   in the Schubert conditions  
//    It is a helper function for makeLagrangianCoordinates
//
proc LagrangianVariables( intvec w, intvec u ) {
  list fcd  = fullColData( w, u );
  list Vars = LagrangianVariables_nFP( w, u );
  if ( size(fcd) > 0 ) {
    int ii;
    intvec new_w = removeFP( w, fcd );
    intvec new_u = removeFP( u, fcd );
    Vars = LagrangianVariables_nFP( new_w, new_u );
    list fPP =  makeFP_pointers( w, u );
    intvec cP = fPP[1];
    intvec rP = fPP[2];

    for (ii=1; ii<=size(Vars[1]); ii++) {
      Vars[1][ii][1] = rP[Vars[1][ii][1]];
      Vars[1][ii][2] = cP[Vars[1][ii][2]];
    }
    for (ii=1; ii<=size(Vars[2]); ii++) {
      Vars[2][ii][1][1] = rP[Vars[2][ii][1][1]];
      Vars[2][ii][1][2] = cP[Vars[2][ii][1][2]];
      Vars[2][ii][2][1] = rP[Vars[2][ii][2][1]];
      Vars[2][ii][2][2] = cP[Vars[2][ii][2][2]];
    }
    intvec newPivots = 1..size(w);
    for (ii=1; ii<=size(Vars[3]); ii++) {
      newPivots[cP[ii]] = rP[Vars[3][ii]];
    }
    for (ii=1; ii<=size(fcd); ii++) {
      newPivots[fcd[ii][1]] = 2*size(w)+1-fcd[ii][2];
    }
    Vars[3]=newPivots;
  }
  return( Vars );
}
////////////////////////////////////////////////////////////////////////////////////////////////////




