// type A
//
// proc makeSymmetricIdeal ( int n, list # )   makes the ideal generated by the elementary symmetric polynomials
// 
// proc makeLongestA ( int n )                 makes the longest element in symmetric group 
//  
// proc simpleReflectionA( intvec w, intvec i )   Applies a simple reflection s_i to a permutation w, returning w s_i
//
// proc reducedWordToTopA ( intvec w )     Makes the reduced word from a permutation w to wo (assumes that w is a permutation
//
// proc topClassA( theRing )  makes the class of a point in the cohomology
//
//  proc dividedDifference ( poly myF, int i )   Computes the i-th divided difference of a polynomial myF
//
//
//




////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  makes the ideal generated by the elementary symmetric polynomials
//
//   n = number of variables
//   # = optional list of strings:  name of variables, name of ideal
//
proc makeSymmetricIdeal ( int n, list # )
"USAGE: makeSymmetricIdeal( n, # )
    Given an integer n, variable name #[1] and ideal name #[2]
    created the symmetric ideal in n variables

 RETURN: A ring constructor containing the ideal

 EXAMPLE: example makeSymmetricIdeal shows an example"
{
 if (size(#)==1) {#[2] = "symmetricIdeal"; }
 if (size(#)<>2) {#[1] = "x"; #[2] = "symmetricIdeal"; }
 string ringConstructor = "ring S = 0, (" + #[1] + "(n..1)), dp;" ;
 ring R = 0, (x(n..1),t), dp;
 int i;
 poly f = 1;
 for ( i=1; i<=n; i=i+1 )
  {
    f = f*( x(i) + t );
  }
  matrix M = coeffs(f,t);
  ideal I = 0;
  for ( i=1; i<=n; i=i+1 )
  {
    I = I + ideal(M[i,1]);
  }
  execute(ringConstructor);
  string idealConstructor = "ideal " + #[2] + " = fetch(R,I);";
  execute(idealConstructor); 
  string exportConstructor = "export( " + #[2] + " );";
  execute(exportConstructor);
  return( list(S, #) );
}
example   
{   
  "EXAMPLE:"; echo = 2;
  def myRing =  makeSymmetricIdeal(3,"y")[1];
  setring myRing;
  symmetricIdeal;
  list L = "z", "J";
  def myRing =  makeSymmetricIdeal(4, L)[1];
  setring myRing;
  J;
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
proc makeLongestA ( int n )
 {
  intvec wo = n;
  for (int i=n-1; i>0; i=i-1)
  {
   wo = wo,  intvec(i);
  }
  return ( wo );
 }
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
// Applies a simple reflection s_i to a permutation w, returning w s_i
//
proc simpleReflectionA ( intvec w, intvec i )
{
 intvec wsi = w;
 wsi[i] = w[i+1];
 wsi[i+1]=w[i];
 return( wsi );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Makes the reduced word from a permutation w to wo (assumes that w is a permutation
//
proc reducedWordToTopA ( intvec w )
{
 int i;
 int n = size(w);
 intvec wrd;
 intvec wc = w;
 intvec wo = makeLongestA(n);
 while ( wc != wo )
 {
  for (i=1; i<=n-1; i=i+1)
  {
   if (wc[i]<wc[i+1])
   {
    wc = simpleReflectionA( wc, i );
    wrd = intvec(i), wrd;
    i = n-1;
   }
  }
 }
 return( delete(wrd, size(wrd)) );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
proc topClassA( theRing )
{
 ring R = theRing;
 int n = nvars( R );
 poly f = 1;
 for (int i=2; i<=n; i=i+1)
 {
  f = f*var(i)^(i-1);
 }
 return( f );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Computes the i-th divided difference of a polynomial myF
//  Because of the way subst acts, need to bring in a new variable
//
proc dividedDifference ( poly myF, int i )
{
 def R = basering;
 int n = nvars(R);
 string A =  "ring Rt = "+ charstr(R) +",("+varstr(R)+",tnew), dp;";
 execute(A);
 print(Rt);
 poly newF = fetch(R, myF );
 poly fst = subst(  subst( subst( newF, var(n+1-i),var(n+1) ) , var(n-i), var(n+1-i) ) , var(n+1), var(n-i) );
 fst = division( newF-fst, ideal( var(n+1-i) -  var(n-i) ) )[1][1,1];
 setring R;
 return( fetch( Rt, fst) );
}
