//SchubertIntersection.lib
//
//   This is code to compute Schubert intersection numbers
//
////////////////////////////////////////////////////////////
LIB "matrix.lib"; 
LIB "linalg.lib"; 
LIB "general.lib";
LIB "random.lib";
////////////////////////////////////////////////////////////


// type A

////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  makes the ideal generated by the elementary symmetric polynomials
//
//   n = number of variables
//   # = optional list of strings:  name of variables, name of ideal
//
proc makeSymmetricIdeal ( int n, list # )
"USAGE: makeSymmetricIdeal( n, # )
    Given an integer n, variable name #[1] and ideal name #[2]
    created the symmetric ideal in n variables

 RETURN: A ring constructor containing the ideal

 EXAMPLE: example makeSymmetricIdeal shows an example"

{
 if (size(#)==1) {#[2] = "symmetricIdeal"; }
 if (size(#)<>2) {#[1] = "x"; #[2] = "symmetricIdeal"; }
 string ringConstructor = "ring S = 0, (" + #[1] + "(1..n)), dp;" ;
// string ringConstructor = "ring S = 0, (y(1..n)), dp;" ;
 ring R = 0, (x(1..n),t), dp;
 int i;
 poly f = 1;
 for ( i=1; i<=n; i=i+1 )
  {
    f = f*( x(i) + t );
  }
  matrix M = coeffs(f,t);
  ideal I = 0;
  for ( i=1; i<=n; i=i+1 )
  {
    I = I + ideal(M[i,1]);
  }
  execute(ringConstructor);
  string idealConstructor = "ideal " + #[2] + " = fetch(R,I);";
  execute(idealConstructor); 
  string exportConstructor = "export( " + #[2] + " );";
  execute(exportConstructor);
  return( list(S, #) );
}
example   
{   
  "EXAMPLE:"; echo = 2;
  def myRing =  makeSymmetricIdeal(3,"y")[1];
  setring myRing;
  symmetricIdeal;
  list L = "z", "J";
  def myRing =  makeSymmetricIdeal(4, L)[1];
  setring myRing;
  J;
}
