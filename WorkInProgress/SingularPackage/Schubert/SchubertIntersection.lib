//SchubertIntersection.lib
//
//   This is code to compute Schubert intersection numbers
//
////////////////////////////////////////////////////////////
LIB "matrix.lib"; 
LIB "linalg.lib"; 
LIB "general.lib";
LIB "random.lib";
////////////////////////////////////////////////////////////
//
//   These all require a base ring with n variables, ideally "ring R = 0, (x(n..1)), dp;"
//
//
// type A
//
// proc makeSymmetricIdeal (  )   makes the ideal generated by the elementary symmetric polynomials  assumes a base ring
// 
// proc makeLongestA ( int n )                 makes the longest element in symmetric group 
//  
// proc simpleReflectionA( intvec w, intvec i )   Applies a simple reflection s_i to a permutation w, returning w s_i
//
// proc reducedWordToTopA ( intvec w )   Makes the reduced word from a permutation w to wo (assumes w is a permutation )
//
// proc topClassA( theRing )  makes the class of a point in the cohomology
//
// proc dividedDifference ( poly myF, int i )   Computes the i-th divided difference of a polynomial myF
//
// proc makeSchubertPolynomialA ( intvec w )    Computes the Schubert polynomial for a partial permutation w
//
// proc makeDualFlagType( intvec flagType )  makes the permutation Poincare dual to the given partial flag variety
//
// proc isSchubertProblemA( intvec flagType, list SchubertProblem ) Checks if SchubertProblem is a Schubert problem for the given flagType
//
//
//
//




////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  makes the ideal generated by the elementary symmetric polynomials
//
//   Assumes a given basering
//
proc makeSymmetricIdeal ( )
"USAGE: makeSymmetricIdeal( )
    Assumes a base ring with n variables creates the symmetric ideal in n variables

 RETURN: the ideal of elementary symmetric functions in the variables of the given ring

 EXAMPLE: example makeSymmetricIdeal shows an example"
{
 int n = nvars(basering);
 def R = basering;
 string ringConstructor = "ring Rt = 0, (" + varstr(R) +", t), dp;";
 execute(ringConstructor);
 int i;
 poly f = 1;
 for ( i=1; i<=n; i=i+1 )
  {
    f = f*( x(i) + t );
  }
  matrix M = coeffs(f,t);
  ideal I = 0;
  for ( i=1; i<=n; i=i+1 )
  {
    I = I + ideal(M[i,1]);
  }
  setring R;
  return( fetch(Rt,I) );
}
example   
{   
  "EXAMPLE:"; echo = 2;
  ring  myRing =  0, (y(5..1)), dp;
  makeSymmetricIdeal( );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
proc makeLongestA ( int n )
 {
  intvec wo = n;
  for (int i=n-1; i>0; i=i-1)
  {
   wo = wo,  intvec(i);
  }
  return ( wo );
 }
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
// Applies a simple reflection s_i to a permutation w, returning w s_i
//
proc simpleReflectionA ( intvec w, intvec i )
{
 intvec wsi = w;
 wsi[i] = w[i+1];
 wsi[i+1]=w[i];
 return( wsi );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Makes the reduced word from a permutation w to wo (assumes that w is a permutation
//
proc reducedWordToTopA ( intvec w )
{
 int i;
 int n = size(w);
 intvec wrd;
 intvec wc = w;
 intvec wo = makeLongestA(n);
 while ( wc != wo )
 {
  for (i=1; i<=n-1; i=i+1)
  {
   if (wc[i]<wc[i+1])
   {
    wc = simpleReflectionA( wc, i );
    wrd = intvec(i), wrd;
    i = n-1;
   }
  }
 }
 return( delete(wrd, size(wrd)) );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
proc topClassA( )
{
 int n = nvars( basering );
 poly f = 1;
 for (int i=2; i<=n; i=i+1)
 {
  f = f*var(i)^(i-1);
 }
 return( f );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Computes the i-th divided difference of a polynomial myF
//  Because of the way subst acts, need to bring in a new variable
//
proc dividedDifference ( poly myF, int i )
{
 def R = basering;
 int n = nvars(R);
 string A =  "ring Rt = "+ charstr(R) +",("+varstr(R)+",tnew), dp;";
 execute(A);
 poly newF = fetch(R, myF );
 poly fst = subst(  subst( subst( newF, var(n+1-i),var(n+1) ) , var(n-i), var(n+1-i) ) , var(n+1), var(n-i) );
 fst = division( newF-fst, ideal( var(n+1-i) -  var(n-i) ) )[1][1,1];
 setring R;
 return( fetch( Rt, fst) );
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Computes the Schubert polynomial for a partial permutation w 
//
//
proc makeSchubertPolynomialA ( intvec w )
{
 int n = nvars( basering );
 if ( isPartialPermutation( w ) and ( n >= sort(w)[1][size(w)] ) )
 {
  intvec wLoc = completeToPermutation(w, n);
  intvec rw = reducedWordToTopA( wLoc );
  ideal symmetricIdeal = std( makeSymmetricIdeal() );
  poly f = topClassA( );
  for (int i=1; i<=size(rw); i=i+1)
  {
    f = dividedDifference( f, rw[i] );
  }
  return( reduce( f,  symmetricIdeal ) );
 }
  else 
 {
  printf("The input intvec to makeSchubertPolynomialA is not a partialPermutation or there are insufficient variables");
 }
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
// makes the permutation that is Poincare dual to the given partial flag variety
//
proc makeDualFlagType( intvec flagType )
{
 intvec wp;
 int i,j;
 intvec extFlagType = intvec(0), flagType;
 int ell = size(flagType);
 for (i=1; i<=size(flagType); i=i+1)
 {
  for (j=1; j<=flagType[i]-extFlagType[i]; j=j+1)
  {
   wp = wp, intvec(flagType[i]+1-j);
  }
 }
 return(delete(wp,1));
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Computes the length of a permutation in type A
//
proc lengthA ( intvec w, int n)
//
{
 w = completeToPermutation(w,n);
 int i,j;
 int len = 0;
 for (i=1; i<size(w); i=i+1)
 {
  for (j=i+1; j<=size(w); j=j+1)
  {
   if (w[i]>w[j]) { len = len +1; }
  }
 }
 return(len);
}
////////////////////////////////////////////////////////////////////////////////////////////////////
////////////////////////////////////////////////////////////////////////////////////////////////////
//
//  Checks if SchubertProblem is a Schubert problem for the given flagType
//
proc isSchubertProblemA( intvec flagType, list SchubertProblem )
{
 int i;
 intvec w;
 int n = flagType[size(flagType)];
 int isSchubProb = 1;
 intvec wp = makeDualFlagType( flagType );
 int dm = lengthA( wp , n );
 for (i=1; i<=size(SchubertProblem); i=i+1)
 {
  if (isCondition( SchubertProblem[i] , flagType ))
  {
    dm = dm + lengthA( SchubertProblem[i] , n );
  }
  else
  {
   isSchubProb = 0 ;
  }
 }
 return( (dm == n*(n-1) div 2) and isSchubProb );
}
